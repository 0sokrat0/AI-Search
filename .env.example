 # MongoDB
MONGO_USER=root
MONGO_PASSWORD=change-me
MONGO_DB=appdb
MONGO_URI=mongodb://root:change-me@localhost:27017/?authSource=admin
MONGO_DB_NAME=appdb

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6334

# App
HTTP_PORT=8080


# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_SESSION_TIMEOUT=15m

# Super Admin
SUPER_ADMIN_ENABLED=true
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-me
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_TENANT_ID=root

# Embeddings
EMBEDDING_PROVIDER=local
EMBEDDING_API_KEY=
EMBEDDING_MODEL_NAME=gemini-embedding-001
LOCAL_EMBEDDING_URL=http://localhost:11434
LOCAL_EMBEDDING_MODEL=qwen3-embedding:0.6b

# Logger
LOGGER_LEVEL=info
LOGGER_ENCODING=json
LOGGER_OUTPUT_PATHS=stdout
